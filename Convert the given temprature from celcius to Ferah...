import java.util.Scanner;

public class Main {
	public static void main(String[] args) {
	    
	    Scanner sc = new Scanner(System.in);
	    double celcius;
	    double fahrenheit;
	    
	    celcius = sc.nextDouble();
	    // logic
	    fahrenheit = (celcius * 9.0 / 5.0) + 32.0;
	    System.out.println(fahrenheit);
	}
}
